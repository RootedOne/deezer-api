# API Authorization Token (Key required in 'X-API-Key' header)
API_KEY=dev-key

# Server Binding
API_HOST=0.0.0.0
API_PORT=8000

# Cache Thresholds
FILE_MAX_AGE_SEC=3600      # Expiry of temporary download links (1 hour)
CLEANUP_INTERVAL_SEC=300   # Sweep loop frequency (5 minutes)

# Deezer ARL Token (Required for download endpoints)
DEEZER_TOKEN=your-deezer-arl-cookie-here
