# API Authorization Token (Key required in 'X-API-Key' header)
API_KEY=dev-key

# Server Binding
API_HOST=0.0.0.0
API_PORT=8000

# Cache Thresholds
FILE_MAX_AGE_SEC=3600      # Expiry of temporary download links (1 hour)
CLEANUP_INTERVAL_SEC=300   # Sweep loop frequency (5 minutes)

# Deezer ARL Tokens (Fallback accounts: DEEZER_TOKEN_1, DEEZER_TOKEN_2, etc.)
DEEZER_TOKEN_1=your-primary-deezer-arl-cookie-here
DEEZER_TOKEN_2=your-second-fallback-arl-cookie-here
# DEEZER_TOKEN=your-legacy-cookie-fallback-here
